          "editorMode": "code",
          "expr": "count(ALERTS{cluster=~\"$cluster\", namespace=~\"$namespace\", alertstate=\"firing\"})",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Active Alerts",
      "type": "stat"

    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Dashboard --"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 7,
      "options": {
        "code": {
          "language": "html",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "<div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding: 16px;\">\n  <div style=\"background: rgba(61, 113, 217, 0.1); border: 1px solid rgba(61, 113, 217, 0.3); border-radius: 8px; padding: 20px; text-align: center;\">\n    <h3 style=\"margin: 0 0 8px 0; color: #6E9FFF;\">L0 - Executive</h3>\n    <p style=\"margin: 0; color: #aaa; font-size: 13px;\">High-level business health, SLOs, and availability overview for leadership.</p>\n    <a href=\"/d/exec-command-center\" style=\"color: #6E9FFF; display: inline-block; margin-top: 12px;\">Executive Command Center &rarr;</a>\n  </div>\n  <div style=\"background: rgba(115, 191, 105, 0.1); border: 1px solid rgba(115, 191, 105, 0.3); border-radius: 8px; padding: 20px; text-align: center;\">\n    <h3 style=\"margin: 0 0 8px 0; color: #73BF69;\">L1 - Service Overview</h3>\n    <p style=\"margin: 0; color: #aaa; font-size: 13px;\">Golden signals, RED metrics, and service health across all namespaces.</p>\n    <a href=\"/d/l1-service-overview\" style=\"color: #73BF69; display: inline-block; margin-top: 12px;\">Service Overview &rarr;</a>\n  </div>\n  <div style=\"background: rgba(255, 152, 48, 0.1); border: 1px solid rgba(255, 152, 48, 0.3); border-radius: 8px; padding: 20px; text-align: center;\">\n    <h3 style=\"margin: 0 0 8px 0; color: #FF9830;\">L2 - Service Detail</h3>\n    <p style=\"margin: 0; color: #aaa; font-size: 13px;\">Deep-dive into individual service metrics, logs, and traces correlation.</p>\n    <a href=\"/d/l2-service-detail\" style=\"color: #FF9830; display: inline-block; margin-top: 12px;\">Service Detail &rarr;</a>\n  </div>\n  <div style=\"background: rgba(255, 73, 73, 0.1); border: 1px solid rgba(255, 73, 73, 0.3); border-radius: 8px; padding: 20px; text-align: center;\">\n    <h3 style=\"margin: 0 0 8px 0; color: #FF4949;\">L3 - Debug</h3>\n    <p style=\"margin: 0; color: #aaa; font-size: 13px;\">Container-level debugging, pod logs, traces, and profiling data.</p>\n    <a href=\"/d/l3-debug\" style=\"color: #FF4949; display: inline-block; margin-top: 12px;\">Debug View &rarr;</a>\n  </div>\n</div>",
        "mode": "html"
      },
      "pluginVersion": "10.4.0",
      "title": "Quick Navigation",
      "type": "text"
    },
    {
      "collapsed": false,

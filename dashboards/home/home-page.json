      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir_uid}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "up{cluster=~\"$cluster\", namespace=~\"$namespace\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Status"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir_uid}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\", status=~\"5..\"}[5m])) / sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 100",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "ErrorRate"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir_uid}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m]))) * 1000",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Latency"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir_uid}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m]))",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Throughput"
        }
      ],
      "title": "Service Health Overview",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "instance": true,
              "namespace": false
            },
            "indexByName": {},
            "renameByName": {
              "Value #ErrorRate": "Error Rate",
              "Value #Latency": "P99 Latency",
              "Value #Status": "Status",
              "Value #Throughput": "Throughput",
              "job": "Service"
            }
          }
        }
      ],
      "type": "table"
    },

      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource_mimir_uid}"
        },
        "enable": true,
        "expr": "changes(kube_deployment_status_observed_generation{namespace=~\"$namespace\"}[2m]) > 0",
        "hide": false,
        "iconColor": "#96D98D",
        "name": "Deployments",
        "step": "60s",
        "tagKeys": "namespace,deployment",
        "titleFormat": "Deployment: {{deployment}}",
        "type": "tags",
        "useValueForTime": false
      }
    ]

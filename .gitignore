# =============================================================================
# Grafana Terraform .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
# Local .terraform directories
.terraform/

# State files (managed by remote backend)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files
*.tfplan
tfplan-*

# Lock file (regenerated by terraform init)
.terraform.lock.hcl

# Secret variable files
*.auto.tfvars
*.auto.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files (used for local development only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
*.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# OS / IDE
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
